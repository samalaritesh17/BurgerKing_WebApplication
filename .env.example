# Backend (export these in your shell / Docker)
DB_URL=jdbc:mysql://localhost:3306/burgerking_db
DB_USERNAME=root
DB_PASSWORD=root

UPLOAD_DIR=uploads

# Must be >= 32 bytes
JWT_SECRET=replace-with-a-long-secret-string-at-least-32-bytes
JWT_EXPIRATION_MS=900000

# Frontend (only used if you update the UI to read VITE_API_BASE_URL)
VITE_API_BASE_URL=http://localhost:8080
